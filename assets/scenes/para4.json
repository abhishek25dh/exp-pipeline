{
  "scenes": [
    {
      "scene_id": "scene_59",
      "voiceover": "You don't check your bank account."
    },
    {
      "scene_id": "scene_60",
      "voiceover": "Bills sit unopened."
    },
    {
      "scene_id": "scene_61",
      "voiceover": "You don't check your credit score."
    },
    {
      "scene_id": "scene_62",
      "voiceover": "You and your partner don't talk about money."
    },
    {
      "scene_id": "scene_63",
      "voiceover": "Avoidance feels safer than dealing with stress or shame."
    },
    {
      "scene_id": "scene_64",
      "voiceover": "But ignoring money problems makes them worse."
    },
    {
      "scene_id": "scene_65",
      "voiceover": "Late fees stack up."
    },
    {
      "scene_id": "scene_66",
      "voiceover": "Your credit score drops."
    },
    {
      "scene_id": "scene_67",
      "voiceover": "Debt grows."
    },
    {
      "scene_id": "scene_68",
      "voiceover": "In the US, many avoid money because they never learned to manage it."
    },
    {
      "scene_id": "scene_69",
      "voiceover": "Schools don't teach personal finance."
    },
    {
      "scene_id": "scene_70",
      "voiceover": "Parents created fear or shame around it."
    },
    {
      "scene_id": "scene_71",
      "voiceover": "Avoidance is also about shame."
    },
    {
      "scene_id": "scene_72",
      "voiceover": "If you don't look, you don't have to admit how bad it is."
    },
    {
      "scene_id": "scene_73",
      "voiceover": "But you can't fix what you won't look at."
    },
    {
      "scene_id": "scene_74",
      "voiceover": "Start small."
    },
    {
      "scene_id": "scene_75",
      "voiceover": "Log into your bank account."
    },
    {
      "scene_id": "scene_76",
      "voiceover": "Check the balance."
    },
    {
      "scene_id": "scene_77",
      "voiceover": "Look at statements."
    },
    {
      "scene_id": "scene_78",
      "voiceover": "Write down what you owe."
    },
    {
      "scene_id": "scene_79",
      "voiceover": "Just knowing is power."
    },
    {
      "scene_id": "scene_80",
      "voiceover": "From there, you can make a plan."
    }
  ]
}